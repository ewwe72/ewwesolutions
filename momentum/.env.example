# Alpaca paper-trading credentials. Copy this file to `.env` and fill in.
# Real .env must be in .gitignore — never commit credentials.

APCA_API_KEY_ID=PK_REPLACE_WITH_YOUR_PAPER_KEY
APCA_API_SECRET_KEY=REPLACE_WITH_YOUR_PAPER_SECRET
APCA_API_BASE_URL=https://paper-api.alpaca.markets
APCA_DATA_URL=https://data.alpaca.markets

# Optional: log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
