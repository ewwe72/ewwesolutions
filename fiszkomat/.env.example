# Required: Anthropic API key for Haiku generation
ANTHROPIC_API_KEY=sk-ant-...

# Required for paid flow (Phase 1): Stripe Checkout
STRIPE_SECRET=sk_live_or_test_...
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# Optional: webhook secret if you wire /stripe/webhook to a Stripe webhook endpoint.
# Without this, the webhook route returns 503 (the redirect path still works).
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: where the app is reachable (used for Stripe success/cancel URLs).
# Default: http://127.0.0.1:8000
FISZKOMAT_PUBLIC_BASE_URL=

# Optional: where uploads + decks live on disk. Default: ./_work
FISZKOMAT_WORK_DIR=

# Optional: bind host/port for `python -m fiszkomat.web`
FISZKOMAT_HOST=127.0.0.1
FISZKOMAT_PORT=8000
