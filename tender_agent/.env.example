# Anthropic API (direct, not Bedrock — keeping this prototype simple)
# `sk-ant-...` from console.anthropic.com.
ANTHROPIC_API_KEY=

# Optional override; defaults to claude-haiku-4-5 (cheap for the prototype).
# Switch to claude-sonnet-4-6 for the final quality run.
TENDER_AGENT_MODEL=claude-haiku-4-5

# Where logs land. Each run appends one line of JSONL with cost + model + duration.
TENDER_AGENT_LOG_DIR=./_logs

# Where sample announcements + drafts get cached so we don't re-fetch on every run.
TENDER_AGENT_SAMPLE_DIR=./_samples
